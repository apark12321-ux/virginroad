rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for validation
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidView(data) {
      return data.keys().hasAll(['count']) &&
             data.keys().size() == 1 &&
             data.count is int &&
             data.count >= 0;
    }

    // Articles/Posts collection rules
    match /posts/{postId} {
      allow read: if true;
      allow create, update: if request.resource.data.secretToken == "virginroad-secure-secret-token-2026";
      allow delete: if false;
    }

    // Views tracker collection rules
    match /views/{postId} {
      allow read: if true;
      allow create, update: if postId is string && postId.size() <= 128 &&
                            request.resource.data.count is int &&
                            request.resource.data.count >= 0;
    }
  }
}

